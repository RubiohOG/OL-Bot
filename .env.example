# Bot token (Discord Developer Portal > Bot)
DISCORD_TOKEN=your_token_here

# Voice channel IDs (right-click > Copy ID with Developer Mode enabled)
LANE_1_CHANNEL_ID=123456789012345678
LANE_2_CHANNEL_ID=123456789012345679

# Command prefix (optional, defaults to !)
COMMAND_PREFIX=!

# Comma-separated Discord role IDs allowed to run commands without being in a lane VC
# (optional; users with Move Members permission are always allowed)
ALLOWED_ROLE_IDS=

# Per-user cooldown between commands in seconds (optional, defaults to 30)
COMMAND_COOLDOWN_SECONDS=30

# --- Required permissions and intents ---
# Invite the bot with: Move Members, View Channels, Connect, Send Messages
# Developer Portal > Bot > Privileged Gateway Intents: enable "Message Content Intent"
# The bot role must be above the roles of users you want to move
